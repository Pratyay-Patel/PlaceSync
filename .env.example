# ─────────────────────────────────────────────────────────────────────────────
# PlaceSync — Environment Variable Template
#
# Copy this file to .env and fill in real values.
# The .env file is git-ignored and must NEVER be committed to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL / Supabase) ──────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/placesync_dev
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here

# ── (Phase 2+) JWT ────────────────────────────────────────────────────────────
# JWT_SECRET=generate-a-256-bit-random-secret-here
# JWT_ACCESS_TOKEN_EXPIRY_MS=900000
# JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ── (Phase 2+) Google OAuth2 ──────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── (Phase 3+) Redis ──────────────────────────────────────────────────────────
# REDIS_HOST=redis
# REDIS_PORT=6379

# ── (Phase 4+) Kafka ──────────────────────────────────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── (Phase 5+) AWS S3 ─────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_RESUMES=placesync-resumes
# AWS_S3_BUCKET_PICTURES=placesync-profile-pictures

# ── (Phase 5+) Email (Gmail SMTP) ─────────────────────────────────────────────
# MAIL_USERNAME=noreply.placesync@gmail.com
# MAIL_APP_PASSWORD=your-gmail-app-password

# ── (Phase 5+) Production Database (Supabase) ────────────────────────────────
# Use the DIRECT connection (port 5432) for Flyway migrations only.
# Use the TRANSACTION POOLER (port 6543) for the running application.
# PROD_DATABASE_URL=jdbc:postgresql://<supabase-host>:6543/postgres?pgbouncer=true
# PROD_DATABASE_USERNAME=postgres
# PROD_DATABASE_PASSWORD=your-supabase-db-password
# PROD_FLYWAY_URL=jdbc:postgresql://<supabase-host>:5432/postgres?sslmode=require

# ── App URLs ──────────────────────────────────────────────────────────────────
# FRONTEND_URL=https://placesync.yourdomain.com
# APP_BASE_URL=https://api.placesync.yourdomain.com
