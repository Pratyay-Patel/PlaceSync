# ─── Maven ────────────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ─── Build artefacts (belt-and-suspenders) ────────────────────────────────────
*.jar
*.war
*.ear
*.class

# ─── IntelliJ IDEA ────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ─── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ─── Spring Boot ──────────────────────────────────────────────────────────────
spring-shell.log

# ─── Environment / Secrets ────────────────────────────────────────────────────
# NEVER commit the real .env file — it contains database credentials and API keys.
.env
.env.prod
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# Documentation (only ignore generated javadoc output, not hand-written markdown)
docs/site/

# ─── Frontend ─────────────────────────────────────────────────────────────────
placesync-frontend/node_modules/
placesync-frontend/dist/
placesync-frontend/.vite/
placesync-frontend/coverage/
